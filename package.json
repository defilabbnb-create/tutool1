{
  "name": "tumvp",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "predev": "node scripts/check-node-version.mjs strict",
    "prebuild": "node scripts/check-node-version.mjs warn",
    "prestart": "node scripts/check-node-version.mjs strict",
    "dev": "env -u NODE_OPTIONS next dev",
    "build": "env -u NODE_OPTIONS next build",
    "start": "env -u NODE_OPTIONS next start",
    "test:unit": "node --import tsx --test tests/unit/**/*.test.ts",
    "test:api": "node --import tsx --test tests/api/**/*.test.ts",
    "test:e2e": "PLAYWRIGHT_TEST_LOCAL=1 playwright test",
    "test:e2e:ui": "PLAYWRIGHT_TEST_LOCAL=1 playwright test --ui",
    "test:e2e:local": "PLAYWRIGHT_TEST_LOCAL=1 playwright test",
    "test:smoke:prod": "RUN_PRODUCTION_SMOKE_TEST=1 playwright test tests/e2e/production-smoke.spec.ts",
    "test:all": "npm run test:unit && npm run test:api && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "jszip": "^3.10.1",
    "next": "15.5.13",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "tsx": "^4.21.0",
    "typescript": "5.7.3"
  }
}
